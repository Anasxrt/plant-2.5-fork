# ===========================
# Dependencies (do not commit)
# ===========================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===========================
# Build Output (generated)
# ===========================
dist/
build/

# ===========================
# IDE & Editor Files
# ===========================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ===========================
# Cache Files
# ===========================
.cache/
*.cache
__pycache__/

# ===========================
# Environment Files
# ===========================
.env
.env.local
.env.*.local

# ===========================
# Test & Coverage
# ===========================
coverage/
.nyc_output/

# ===========================
# Temporary Files
# ===========================
tmp/
temp/
*.tmp

# ===========================
# Misc
# ===========================
*.log

# ===========================
# Seed Webs (forked - not needed)
# ===========================
vendor/seedwebs/

# ===========================
# Build Output (CSS - generated from SCSS, should be built for production)
# ===========================
css/*.css
css/*.css.map
css/scss/*.css
css/scss/*.css.map
css/scss/*.min.css
css/scss/*.css.map
